# Environment Variables
#
# Copy this file to .env and fill in your API keys.
# DO NOT commit .env to version control!

# ============================================
# AI Model API Keys (REQUIRED)
# ============================================

# Gemini (Required for data gathering)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Strategy Model (Choose ONE as primary)
# Uncomment the one you want to use:

# DeepSeek (Default - cost-effective, good reasoning)
# Get yours at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
STRATEGY_MODEL_PROVIDER=deepseek

# Claude (Conservative, safety-focused)
# Get yours at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# STRATEGY_MODEL_PROVIDER=claude

# Qwen via DashScope (Very cheap)
# Get yours at: https://dashscope.aliyun.com/
# DASHSCOPE_API_KEY=your_dashscope_api_key_here
# STRATEGY_MODEL_PROVIDER=qwen

# GPT-4 (Best reasoning, most expensive)
# Get yours at: https://platform.openai.com/
# OPENAI_API_KEY=your_openai_api_key_here
# STRATEGY_MODEL_PROVIDER=gpt

# ============================================
# Alpaca API Credentials
# Get yours at: https://alpaca.markets
# ============================================
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# ============================================
# OKX API Credentials
# Get yours at: https://www.okx.com/account/my-api
# ============================================
OKX_API_KEY=your_okx_api_key_here
OKX_API_SECRET=your_okx_api_secret_here
OKX_PASSPHRASE=your_okx_passphrase_here

# ============================================
# CoinGecko API Key (optional)
# Free tier works without key
# Pro: https://www.coingecko.com/en/api/pricing
# ============================================
# COINGECKO_API_KEY=your_coingecko_api_key_here

# ============================================
# Polymarket Note:
# The Gamma API used for market data requires NO authentication.
# Trading on Polymarket is NOT implemented in TraderClaw.
# ============================================
